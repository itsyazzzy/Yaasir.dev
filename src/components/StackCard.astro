---
interface Props {
  name: string;
  category: string;
  description: string;
  color?: string;
  rotate?: 'cw' | 'ccw';
}

const { name, category, description, color = '#2dd4bf', rotate = 'cw' } = Astro.props;
const rotateClass = rotate === 'cw' ? 'card-rotate-1' : 'card-rotate-2';
---

<div class={`w-full min-w-64 min-h-64 ${rotateClass}`}>
  <div class="gradient-card ring-1 ring-[var(--color-base-800)] rounded-2xl
              p-6 h-full flex flex-col justify-between
              hover:ring-[var(--color-accent)]/30 hover:shadow-[var(--glow-teal)]
              transition-all duration-300 group">

    <div class="flex items-center justify-between gap-4">
      <div>
        <h3 class="text-sm font-medium text-[var(--color-base-100)]">{name}</h3>
        <p class="text-xs font-mono text-[var(--color-base-600)] mt-0.5">{category}</p>
      </div>
      <!-- Color dot as icon -->
      <div
        class="size-8 rounded-xl flex-shrink-0 group-hover:rotate-45 transition-transform duration-300"
        style={`background-color: ${color}22; border: 1px solid ${color}44;`}
      >
        <div class="size-full rounded-xl flex items-center justify-center">
          <div class="size-2 rounded-full" style={`background-color: ${color};`}></div>
        </div>
      </div>
    </div>

    <p class="text-xs text-[var(--color-base-500)] mt-4 leading-relaxed">
      {description}
    </p>
  </div>
</div>
