---
interface Props {
  title: string;
  href?: string;
  linkLabel?: string;
}
const { title, href, linkLabel = 'See all' } = Astro.props;
---

<div class="flex items-end justify-between mb-6">
  <h2 class="font-display italic text-2xl sm:text-3xl text-[var(--color-text-heading)] tracking-wide">
    {title}
  </h2>
  {href && (
    <a
      href={href}
      class="btn-secondary text-xs rounded-full px-4 py-2 font-medium
             bg-[var(--color-base-900)] border border-[var(--color-base-800)]
             text-[var(--color-base-400)] hover:text-[var(--color-base-50)]
             hover:border-[var(--color-base-700)]
             transition-all duration-200"
    >
      {linkLabel}
    </a>
  )}
</div>
