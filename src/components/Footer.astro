---
import { profile } from '@/data/site';
---

<footer class="relative z-10 border-t border-[var(--color-base-900)] mt-24">
  <div class="px-8 mx-auto max-w-3xl py-16 flex flex-col items-center gap-6">

    <!-- Copyright -->
    <p class="text-xs text-[var(--color-base-600)] text-center font-mono">
      © {new Date().getFullYear()} {profile.name}
    </p>

    <!-- Social links -->
    <div class="flex items-center gap-6">
      {profile.links.map(link => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-mono text-[var(--color-base-600)]
                 hover:text-[var(--color-accent)] transition-colors duration-200 link-underline"
        >
          {link.label}
        </a>
      ))}
      <a
        href={`mailto:${profile.email}`}
        class="text-xs font-mono text-[var(--color-base-600)]
               hover:text-[var(--color-accent)] transition-colors duration-200 link-underline"
      >
        Email
      </a>
    </div>
  </div>
</footer>
