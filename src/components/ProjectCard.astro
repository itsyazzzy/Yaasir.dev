---
interface Props {
  title: string;
  description: string;
  href: string;
  tags?: string[];
  image?: string;
}

const { title, description, href, tags = [], image } = Astro.props;
---

<div class="relative group gradient-card rounded-3xl overflow-hidden
            min-h-60 flex flex-col justify-between
            hover:border-[rgba(30,144,255,0.25)]
            transition-all duration-300">

  <!-- Full card link -->
  <a href={href} title={`Read more about ${title}`} class="absolute inset-0 z-10" aria-label={title}></a>

  <!-- Top row: logo + title & action button -->
  <div class="p-6 pb-2">
    <div class="flex items-center justify-between gap-4 mb-4">
      {image ? (
        <div class="size-11 rounded-xl overflow-hidden bg-[var(--color-base-900)] ring-1 ring-[var(--color-base-800)] flex items-center justify-center p-2">
          <img src={image} alt={title} class="size-full object-contain" />
        </div>
      ) : (
        <div class="size-11 rounded-xl overflow-hidden bg-[var(--color-base-900)] ring-1 ring-[var(--color-base-800)] flex items-center justify-center">
          <span class="text-sm font-mono text-[var(--color-accent)] font-bold">{title.slice(0, 2).toUpperCase()}</span>
        </div>
      )}

      <div class="size-7 shrink-0 rounded-full flex items-center justify-center
                  bg-[var(--color-accent)]/10 text-[var(--color-accent)]
                  group-hover:bg-[var(--color-accent)] group-hover:text-white
                  group-hover:scale-110 group-hover:rotate-45 transition-all duration-300
                  ring-1 ring-[var(--color-accent)]/20">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="size-3.5">
          <path d="M228,128a12,12,0,0,1-12,12H140v76a12,12,0,0,1-24,0V140H40a12,12,0,0,1,0-24h76V40a12,12,0,0,1,24,0v76h76A12,12,0,0,1,228,128Z"/>
        </svg>
      </div>
    </div>

    <h3 class="text-sm font-medium text-[var(--color-text-heading)] leading-tight">
      {title}
    </h3>
  </div>

  <!-- Content -->
  <div class="px-6 pb-6 flex-1 flex flex-col justify-between gap-4">
    <p class="text-sm text-[var(--color-text-body)] leading-relaxed text-balance">
      {description}
    </p>

    <!-- Hover reveal -->
    <div class="card-reveal flex flex-col gap-3">
      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.slice(0, 4).map(tag => (
            <span class="text-xs font-mono px-2 py-0.5 rounded-full
                         bg-[var(--color-tag-bg)] text-[var(--color-text-muted)]
                         ring-1 ring-[var(--color-tag-border)]">
              {tag}
            </span>
          ))}
        </div>
      )}

      <span class="inline-flex items-center gap-1 text-xs font-medium rounded-full px-4 py-1.5
                   bg-[var(--color-accent)] text-white
                   pointer-events-none w-fit
                   shadow-[0_2px_12px_rgba(30,144,255,0.3)]">
        View project →
      </span>
    </div>
  </div>
</div>
