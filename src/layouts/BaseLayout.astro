---
import '../styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Yasir Hassan — Solutions Architect & Software Engineer',
  description = 'Navigating the deep waters of full-stack architecture and AI-native systems. High-performance logic. Minimal visual noise.',
  image = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="robots" content="index, follow" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Yasir Hassan" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@siryasirrr" />
    <meta name="twitter:creator" content="@siryasirrr" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/sirc.png" type="image/png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Yasir Hassan",
        "url": "https://yaasir.dev",
        "jobTitle": "Solutions Architect & Software Engineer",
        "sameAs": [
          "https://github.com/sirrryasir",
          "https://linkedin.com/in/sirryasir",
          "https://twitter.com/siryasirrr"
        ]
      }
    </script>

    <!-- Dark mode: set before render to avoid flash -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = saved ? saved === 'dark' : prefersDark;
        // Dark = no class on html; Light = html.light
        document.documentElement.classList.toggle('light', !isDark);
      })();
    </script>
  </head>

  <body class="bg-glow min-h-svh flex flex-col relative overflow-x-hidden">
    <div id="cursor-spotlight"></div>
    <Header />
    <main class="relative z-10 flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Theme toggle (bottom-left, Flaco style) -->
    <button
      id="theme-toggle"
      aria-label="Toggle theme"
      class="fixed z-50 bottom-4 left-4 size-9 rounded-full flex items-center justify-center
             bg-[var(--color-base-900)] border border-[var(--color-base-800)]
             text-[var(--color-base-400)] hover:text-[var(--color-base-50)]
             hover:border-[var(--color-base-700)] transition-all duration-300"
    >
      <!-- Sun (shown in dark mode) -->
      <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="size-4">
        <path d="M120,40V16a8,8,0,0,1,16,0V40a8,8,0,0,1-16,0Zm72,88a64,64,0,1,1-64-64A64.07,64.07,0,0,1,192,128Zm-16,0a48,48,0,1,0-48,48A48.05,48.05,0,0,0,176,128ZM58.34,69.66A8,8,0,0,0,69.66,58.34l-16-16A8,8,0,0,0,42.34,53.66Zm0,116.68-16,16a8,8,0,0,0,11.32,11.32l16-16a8,8,0,0,0-11.32-11.32ZM192,72a8,8,0,0,0,5.66-2.34l16-16a8,8,0,0,0-11.32-11.32l-16,16A8,8,0,0,0,192,72Zm5.66,114.34a8,8,0,0,0-11.32,11.32l16,16a8,8,0,0,0,11.32-11.32ZM48,128a8,8,0,0,0-8-8H16a8,8,0,0,0,0,16H40A8,8,0,0,0,48,128Zm80,80a8,8,0,0,0-8,8v24a8,8,0,0,0,16,0V216A8,8,0,0,0,128,208Zm112-88H216a8,8,0,0,0,0,16h24a8,8,0,0,0,0-16Z"/>
      </svg>
      <!-- Moon (shown in light mode) -->
      <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="size-4 hidden">
        <path d="M235.54,150.21a104.84,104.84,0,0,1-37,52.91A104,104,0,0,1,32,120,103.09,103.09,0,0,1,52.88,57.48a104.84,104.84,0,0,1,52.91-37,8,8,0,0,1,10,10,88.08,88.08,0,0,0,109.8,109.8,8,8,0,0,1,10,10Z"/>
      </svg>
    </button>

    <script>
      const toggle = document.getElementById('theme-toggle');
      const sun    = document.getElementById('icon-sun');
      const moon   = document.getElementById('icon-moon');
      const spotlight = document.getElementById('cursor-spotlight');

      function applyTheme(dark: boolean) {
        document.documentElement.classList.toggle('light', !dark);
        sun!.classList.toggle('hidden', !dark);
        moon!.classList.toggle('hidden', dark);
        localStorage.setItem('theme', dark ? 'dark' : 'light');
      }

      // Init
      const saved = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const isDark = saved ? saved === 'dark' : prefersDark;
      applyTheme(isDark);

      toggle!.addEventListener('click', () => {
        const currentlyDark = !document.documentElement.classList.contains('light');
        applyTheme(!currentlyDark);
      });

      // Interactive mouse follow spotlight
      document.addEventListener('mousemove', (e) => {
        if (spotlight && !document.documentElement.classList.contains('light')) {
          spotlight.style.setProperty('--x', `${e.clientX}px`);
          spotlight.style.setProperty('--y', `${e.clientY}px`);
          spotlight.style.opacity = '1';
        }
      });
    </script>
  </body>
</html>
