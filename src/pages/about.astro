---
import BaseLayout from '@/layouts/BaseLayout.astro';
import StackCard from '@/components/StackCard.astro';
import { profile, experience, education, achievements, stack, skills } from '@/data/site';

const title = `About — ${profile.name}`;
const description = "Solutions Architect and Senior Software Engineer specializing in high-performance full-stack architecture and AI-native systems.";
---

<BaseLayout title={title} description={description}>
  <div class="px-8 mx-auto max-w-3xl pt-32 pb-24 space-y-32">
    
    <!-- Hero / Who Am I -->
    <section>
      <h1 class="font-display italic text-4xl sm:text-5xl text-[var(--color-text-heading)] mb-8">About</h1>
      <div class="prose prose-invert prose-base prose-p:text-[var(--color-base-400)] max-w-none leading-relaxed space-y-2">
        <p class="text-xl text-[var(--color-base-200)] font-medium mb-4">
          👋, I'm Yasir Hassan.
        </p>
        <p>Solutions Architect and Senior Software Engineer.</p>
        <p>Based in Hargeisa, Somaliland.</p>
        <p>Beside coding, I focus on building high-performance logic and minimalist developer tools.</p>
      </div>
    </section>

    <!-- Deep Dive Skills -->
    <section>
      <h3 class="font-display italic text-2xl text-[var(--color-text-heading)] mb-8">Technical Arsenal</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 p-8 rounded-3xl border border-[var(--color-base-800)] bg-[var(--color-base-900)]/30">
        {skills.map(skillGroup => (
          <div>
            <h4 class="text-sm font-medium text-[var(--color-base-200)] mb-4">{skillGroup.group}</h4>
            <ul class="space-y-3">
              {skillGroup.items.map(item => (
                <li class="text-xs font-mono text-[var(--color-base-500)] flex items-start gap-2">
                  <span class="size-1 rounded-full bg-[var(--color-accent)] mt-1.5 shrink-0"></span>
                  <span class="leading-tight">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Timeline -->
    <section>
      <h2 class="font-display italic text-3xl text-[var(--color-text-heading)] mb-10">Journey</h2>
      <div class="space-y-8">
        
        {achievements.map(a => (
          <div class="grid grid-cols-[100px_1fr] gap-4 items-baseline">
            <span class="text-sm font-mono text-[var(--color-base-500)]">{a.date.split(' ')[1] || a.date}</span>
            <div>
              <p class="text-base text-[var(--color-base-200)]">{a.title}</p>
              <p class="text-sm text-[var(--color-base-500)]">{a.organizer}</p>
            </div>
          </div>
        ))}

        {education.map(edu => (
          <div class="grid grid-cols-[100px_1fr] gap-4 items-baseline">
            <span class="text-sm font-mono text-[var(--color-base-500)]">{edu.period}</span>
            <div>
              <p class="text-base text-[var(--color-base-200)]">{edu.title}</p>
              <p class="text-sm text-[var(--color-base-500)]">{edu.institution}</p>
            </div>
          </div>
        ))}

        {experience.map(exp => (
          <div class="grid grid-cols-[100px_1fr] gap-4 items-baseline">
            <span class="text-sm font-mono text-[var(--color-base-500)]">{exp.period.split(' ')[0]}</span>
            <div>
              <p class="text-base text-[var(--color-base-200)]">{exp.title}</p>
              <p class="text-sm text-[var(--color-base-500)]">{exp.company}</p>
            </div>
          </div>
        ))}

      </div>
    </section>

    <!-- Embedded Contact Section -->
    <section class="border-t border-[var(--color-base-900)] pt-24 text-center">
      <h2 class="font-display italic text-4xl sm:text-5xl text-[var(--color-text-heading)] mb-6">Let's Connect</h2>
      <p class="text-[var(--color-base-400)] mb-12 max-w-xl mx-auto leading-relaxed">
        I'm currently available for consulting, open-source collaborations, and interesting architectural challenges. If you want to build something together, my inbox is open.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`mailto:${profile.email}`}
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-full px-8 py-4 text-sm font-medium
                 bg-[var(--color-base-100)] text-[var(--color-base-950)]
                 hover:bg-white hover:scale-105
                 transition-all duration-300"
        >
          {profile.email}
        </a>
        <a
          href={profile.links.find(l => l.label === 'LinkedIn')?.href}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-full px-8 py-4 text-sm font-medium
                 border border-[var(--color-base-700)] text-[var(--color-base-300)]
                 hover:text-[var(--color-base-50)] hover:border-[var(--color-accent)]/50
                 transition-all duration-300"
        >
          LinkedIn
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
