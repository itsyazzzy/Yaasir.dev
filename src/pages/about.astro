---
import BaseLayout from '@/layouts/BaseLayout.astro';
import StackCard from '@/components/StackCard.astro';
import { profile, experience, education, achievements, stack, skills } from '@/data/site';

const title = `About — ${profile.name}`;
const description = "Solutions Architect and Senior Software Engineer specializing in high-performance full-stack architecture and AI-native systems.";
---

<BaseLayout title={title} description={description}>
  <div class="px-8 mx-auto max-w-3xl pt-32 pb-24 space-y-32">
    
    <!-- Hero / Who Am I -->
    <section>
      <h1 class="font-display italic text-4xl sm:text-5xl text-[var(--color-text-heading)] mb-8">Who am I?</h1>
      <div class="prose prose-invert prose-base prose-p:text-[var(--color-base-400)] max-w-none leading-relaxed space-y-6">
        <p class="text-xl text-[var(--color-base-200)] font-medium">
          I am a self-taught Software Engineer and Solutions Architect navigating the deep waters of full-stack architecture and AI-native systems.
        </p>
        <p>
          My work is defined by high-performance logic and minimal visual noise, strictly adhering to the <strong>KISS (Keep It Simple, Stupid)</strong> philosophy. I believe that the best systems are not the most complex ones, but the ones that solve real problems with the least amount of friction.
        </p>
        <p>
          Currently based in Hargeisa, Somaliland, my focus spans from engineering production-grade ETL frameworks (like the Aduunyo Migration Engine) to building award-winning, large-scale social ecosystems (like the OGAAL Water Intelligence Platform). I specialize in <strong>Go, TypeScript, and Python</strong>, architecting solutions that range from Socratic AI CLIs to robust database GUIs.
        </p>
        <p>
          As a mentor at Ardaykaab Academy, I am also deeply committed to bridging the gap between theory and industry-level implementation, leading student cohorts in building production-ready architectures.
        </p>
      </div>
    </section>

    <!-- The Stack (Moved from dedicated page) -->
    <section>
      <div class="mb-12">
        <h2 class="font-display italic text-3xl sm:text-4xl text-[var(--color-text-heading)]">The Stack</h2>
        <p class="mt-3 text-sm text-[var(--color-base-500)] max-w-lg leading-relaxed">
          The core technologies I use to architect and build high-performance systems.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        {stack.map((tool, i) => (
          <StackCard
            name={tool.name}
            category={tool.category}
            description={tool.description}
            color={tool.color}
            rotate={i % 2 === 0 ? 'cw' : 'ccw'}
          />
        ))}
      </div>
    </section>

    <!-- Deep Dive Skills -->
    <section>
      <h3 class="font-display italic text-2xl text-[var(--color-text-heading)] mb-8">Technical Arsenal</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 p-8 rounded-3xl border border-[var(--color-base-800)] bg-[var(--color-base-900)]/30">
        {skills.map(skillGroup => (
          <div>
            <h4 class="text-sm font-medium text-[var(--color-base-200)] mb-4">{skillGroup.group}</h4>
            <ul class="space-y-3">
              {skillGroup.items.map(item => (
                <li class="text-xs font-mono text-[var(--color-base-500)] flex items-start gap-2">
                  <span class="size-1 rounded-full bg-[var(--color-accent)] mt-1.5 shrink-0"></span>
                  <span class="leading-tight">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Experience & Education Grid -->
    <section class="grid md:grid-cols-2 gap-16">
      <!-- Experience -->
      <div>
        <h2 class="font-display italic text-3xl text-[var(--color-text-heading)] mb-10">Experience</h2>
        <div class="relative pl-6 border-l-2 border-[var(--color-base-800)] space-y-12">
          {experience.map(exp => (
            <div class="relative">
              <div class="absolute -left-[1.6rem] top-1 size-2.5 rounded-full bg-[var(--color-base-950)] border-2 border-[var(--color-accent)]"></div>
              <div class="flex flex-col gap-1 mb-3">
                <span class="text-xs font-mono text-[var(--color-accent)]">{exp.period}</span>
                <p class="text-base font-semibold text-[var(--color-text-heading)]">{exp.title}</p>
                <p class="text-xs font-mono text-[var(--color-base-500)]">{exp.company}</p>
              </div>
              <p class="text-sm text-[var(--color-base-400)] leading-relaxed">{exp.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Education & Awards -->
      <div class="space-y-16">
        <div>
          <h2 class="font-display italic text-3xl text-[var(--color-text-heading)] mb-8">Awards</h2>
          <div class="space-y-6">
            {achievements.map(a => (
              <div class="relative group">
                <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-accent)]/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-xl -m-4 p-4"></div>
                <div class="relative">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-2xl">🏆</span>
                    <p class="text-sm font-semibold text-[var(--color-base-100)]">{a.title}</p>
                  </div>
                  <p class="text-xs font-mono text-[var(--color-base-500)] mb-3">{a.organizer} — {a.date}</p>
                  <p class="text-sm text-[var(--color-base-400)] leading-relaxed">{a.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h2 class="font-display italic text-3xl text-[var(--color-text-heading)] mb-8">Education</h2>
          <div class="space-y-6">
            {education.map(edu => (
              <div class="flex flex-col gap-1 border-b border-[var(--color-base-800)] pb-4 last:border-0">
                <div class="flex justify-between items-baseline gap-4">
                  <p class="text-sm font-medium text-[var(--color-text-heading)]">{edu.title}</p>
                  <span class="text-xs font-mono text-[var(--color-accent)] shrink-0">{edu.period}</span>
                </div>
                <p class="text-xs font-mono text-[var(--color-base-500)]">{edu.institution}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Embedded Contact Section -->
    <section class="border-t border-[var(--color-base-900)] pt-24 text-center">
      <h2 class="font-display italic text-4xl sm:text-5xl text-[var(--color-text-heading)] mb-6">Let's Connect</h2>
      <p class="text-[var(--color-base-400)] mb-12 max-w-xl mx-auto leading-relaxed">
        I'm currently available for consulting, open-source collaborations, and interesting architectural challenges. If you want to build something together, my inbox is open.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`mailto:${profile.email}`}
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-full px-8 py-4 text-sm font-medium
                 bg-[var(--color-base-100)] text-[var(--color-base-950)]
                 hover:bg-white hover:scale-105
                 transition-all duration-300"
        >
          {profile.email}
        </a>
        <a
          href={profile.links.find(l => l.label === 'LinkedIn')?.href}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-full px-8 py-4 text-sm font-medium
                 border border-[var(--color-base-700)] text-[var(--color-base-300)]
                 hover:text-[var(--color-base-50)] hover:border-[var(--color-accent)]/50
                 transition-all duration-300"
        >
          LinkedIn
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
