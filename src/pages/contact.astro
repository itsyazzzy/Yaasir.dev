---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { profile } from '@/data/site';

const title = `Contact — ${profile.name}`;
const description = "Get in touch for collaborations, consulting, or just to say hi.";
---

<BaseLayout title={title} description={description}>
  <div class="px-8 mx-auto max-w-xl pt-32 pb-24 text-center">
    
    <h1 class="font-display italic text-4xl sm:text-5xl text-[var(--color-text-heading)] mb-6">Contact</h1>
    
    <p class="text-[var(--color-base-400)] mb-12 leading-relaxed">
      I'm currently available for consulting, open-source collaborations, and interesting architectural challenges. If you want to build something together, my inbox is open.
    </p>

    <div class="space-y-6">
      <a
        href={`mailto:${profile.email}`}
        class="block w-full rounded-2xl border border-[var(--color-base-800)] bg-[var(--color-base-900)]/50 p-6 
               hover:bg-[var(--color-base-800)] hover:border-[var(--color-accent)]/50 transition-all duration-300 group"
      >
        <p class="text-sm font-medium text-[var(--color-base-300)] mb-1">Email</p>
        <p class="text-lg font-mono text-[var(--color-text-heading)] group-hover:text-[var(--color-accent)] transition-colors">
          {profile.email}
        </p>
      </a>

      <div class="grid grid-cols-2 gap-6">
        <a
          href={profile.links.find(l => l.label === 'LinkedIn')?.href}
          target="_blank"
          rel="noopener noreferrer"
          class="block rounded-2xl border border-[var(--color-base-800)] bg-[var(--color-base-900)]/50 p-6 
                 hover:bg-[var(--color-base-800)] transition-all duration-300"
        >
          <p class="text-sm font-medium text-[var(--color-base-300)] mb-1">Network</p>
          <p class="font-mono text-[var(--color-text-heading)]">LinkedIn</p>
        </a>

        <a
          href={profile.links.find(l => l.label === 'GitHub')?.href}
          target="_blank"
          rel="noopener noreferrer"
          class="block rounded-2xl border border-[var(--color-base-800)] bg-[var(--color-base-900)]/50 p-6 
                 hover:bg-[var(--color-base-800)] transition-all duration-300"
        >
          <p class="text-sm font-medium text-[var(--color-base-300)] mb-1">Code</p>
          <p class="font-mono text-[var(--color-text-heading)]">GitHub</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
