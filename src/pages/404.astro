---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Yasir Hassan" description="Page not found">
  <div class="px-8 mx-auto max-w-3xl pt-48 pb-24 text-center">
    <p class="font-mono text-xs text-[var(--color-base-700)] uppercase tracking-widest mb-4">404</p>
    <h1 class="font-display italic text-4xl sm:text-6xl text-[var(--color-base-300)] mb-6">
      Nothing here.
    </h1>
    <p class="text-sm text-[var(--color-base-600)] mb-10">
      This page doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium
             bg-[var(--color-base-900)] border border-[var(--color-base-800)]
             text-[var(--color-base-400)] hover:text-[var(--color-base-50)]
             hover:border-[var(--color-base-700)] transition-all duration-200"
    >
      ← Go home
    </a>
  </div>
</BaseLayout>
