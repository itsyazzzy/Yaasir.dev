---
import BaseLayout from '@/layouts/BaseLayout.astro';
import StackCard from '@/components/StackCard.astro';
import { stack, skills } from '@/data/site';
---

<BaseLayout
  title="Stack — Yasir Hassan"
  description="The tools, frameworks, and languages I use to build products."
>
  <div class="px-8 mx-auto max-w-3xl pt-32 pb-24">
    <div class="mb-12">
      <h1 class="font-display italic text-4xl sm:text-5xl text-[var(--color-text-heading)]">Stack</h1>
      <p class="mt-3 text-sm text-[var(--color-base-500)] max-w-lg leading-relaxed">
        The tools and technologies I reach for when building products.
      </p>
    </div>

    <!-- Stack cards grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-16">
      {stack.map((tool, i) => (
        <StackCard
          name={tool.name}
          category={tool.category}
          description={tool.description}
          color={tool.color}
          rotate={i % 2 === 0 ? 'cw' : 'ccw'}
        />
      ))}
    </div>

    <!-- Skills grouped list -->
    <div class="border-t border-[var(--color-border-subtle)] pt-12">
      <h2 class="font-display italic text-2xl text-[var(--color-text-heading)] mb-8">Skills</h2>
      <div class="grid sm:grid-cols-2 gap-8">
        {skills.map(group => (
          <div>
            <h3 class="text-xs font-mono text-[var(--color-base-600)] uppercase tracking-widest mb-3">
              {group.group}
            </h3>
            <div class="flex flex-wrap gap-2">
              {group.items.map(item => (
                <span class="text-sm font-mono px-3 py-1 rounded-full
                             bg-[var(--color-tag-bg)] border border-[var(--color-tag-border)]
                             text-[var(--color-text-body)]">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
