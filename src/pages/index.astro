---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import BlogCard from '@/components/BlogCard.astro';
import StackCard from '@/components/StackCard.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { profile, stack, experience, education, achievements } from '@/data/site';

const allProjects = (await getCollection('projects'))
  .filter(project => project.data.featured && project.data.draft !== true)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const allPosts = (await getCollection('blog'))
  .filter(post => post.data.draft !== true)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const featuredStack = stack.slice(0, 6);
---

<BaseLayout>
  <!-- Hero -->
  <HeroSection />

  <div class="px-8 mx-auto max-w-3xl space-y-24 pb-24">

    <!-- Projects section -->
    <section>
      <SectionHeader title="Projects" href="/projects/" linkLabel="See them all" />
      <div class="grid gap-3 md:grid-cols-2">
        {allProjects.map(project => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            href={`/projects/${project.id.replace(/\.md$/, '')}/`}
            tags={project.data.tags}
            image={project.data.image}
          />
        ))}
      </div>
    </section>

    <!-- Blog section -->
    <section>
      <SectionHeader title="Writing" href="/blog/" linkLabel="Read all posts" />
      <div class="flex flex-col gap-3">
        {allPosts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.id.replace(/\.md$/, '')}/`}
            date={post.data.date}
            readTime={post.data.readTime}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>

    <!-- Stack marquee section -->
    <section>
      <SectionHeader title="Stack" href="/about/" linkLabel="See details" />
      <div class="relative overflow-hidden">
        <!-- Fade edges -->
        <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-20
                    bg-gradient-to-r from-[var(--color-bg-fade)] to-transparent"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-20
                    bg-gradient-to-l from-[var(--color-bg-fade)] to-transparent"></div>

        <div class="flex gap-3 py-12 animate-marquee">
          {[...featuredStack, ...featuredStack].map((tool, i) => (
            <StackCard
              name={tool.name}
              category={tool.category}
              description={tool.description}
              color={tool.color}
              rotate={i % 2 === 0 ? 'cw' : 'ccw'}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Contact CTA -->
    <section class="text-center py-12">
      <p class="font-display italic text-3xl sm:text-4xl text-[var(--color-base-300)] mb-6">
        Let's build something.
      </p>
      <a
        href="mailto:sir@yaasir.dev"
        class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-medium
               bg-[var(--color-accent)] text-white
               hover:bg-[var(--color-accent-dim)]
               shadow-[0_4px_32px_rgba(30,144,255,0.3)]
               hover:shadow-[0_4px_48px_rgba(30,144,255,0.45)]
               transition-all duration-300"
      >
        sir@yaasir.dev
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="size-3.5">
          <path d="M184.49,136.49l-80,80a12,12,0,0,1-17-17L159,128,87.51,56.49a12,12,0,1,1,17-17l80,80A12,12,0,0,1,184.49,136.49Z"/>
        </svg>
      </a>
    </section>

  </div>
</BaseLayout>
